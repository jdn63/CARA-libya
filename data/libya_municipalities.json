  "_metadata": {
    "title": "Libya Municipalities — CARA Assessment Units",
    "description": "Administrative Level 3 municipalities (baladiyyat) of Libya for use in the CARA subnational risk assessment tool. Organized within Level 2 districts (mantiqaat) and Level 1 historical regions.",
    "target_count": 148,
    "current_count": 104,
    "data_gap_note": "This file currently contains 104 municipalities drawn from published UNOCHA, IOM, and academic sources. Approximately 44 additional sub-municipal units (primarily fragmented urban zones in Tripoli, Benghazi, and Misrata metropolitan areas) require verification and addition from official Libyan government administrative records before the tool reaches the full 148-municipality target agreed at the April 2026 workshop. All municipality entries should be validated against Libya's High National Elections Commission records or the Ministry of Local Government municipal registry.",
    "provenance": "Compiled from: UNOCHA Libya Humanitarian Response Plan administrative units (2023); IOM Displacement Tracking Matrix Libya operational coverage; academic literature on post-2011 Libyan administrative reorganization. Population estimates from 2018 Libya Municipal Council election base data and IOM DTM 2022.",
    "coordinate_system": "EPSG:4326 (WGS84)",
    "last_updated": "2026-04-23",
    "verified_by": "Pending verification by Libya Ministry of Local Government"
  },
